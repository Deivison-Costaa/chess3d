{
  "version": 3,
  "configurePresets": [
    {
      "name": "windows-mingw",
      "displayName": "Windows MinGW (MSYS2 + vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-mingw-dynamic",
        "CMAKE_C_COMPILER":   "C:/msys64/mingw64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER": "C:/msys64/mingw64/bin/g++.exe",
        "CMAKE_MAKE_PROGRAM": "C:/msys64/mingw64/bin/ninja.exe"
      }
    },
    {
      "name": "linux-gcc",
      "displayName": "Linux GCC (vcpkg)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-linux"
      }
    },
    {
      "name": "ci-windows",
      "displayName": "CI Windows (GitHub Actions)",
      "inherits": "windows-mingw",
      "cacheVariables": {
        "CMAKE_C_COMPILER":   "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_MAKE_PROGRAM": "ninja"
      }
    },
    {
      "name": "ci-linux",
      "displayName": "CI Linux (GitHub Actions)",
      "inherits": "linux-gcc"
    },
    {
      "name": "package-windows",
      "displayName": "Package Windows (.exe auto-extraível, estático)",
      "inherits": "windows-mingw",
      "binaryDir": "${sourceDir}/build-package",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-mingw-static",
        "CHESS3D_PACKAGE": "ON",
        "CHESS3D_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "package-linux",
      "displayName": "Package Linux (binário p/ AppImage)",
      "inherits": "linux-gcc",
      "binaryDir": "${sourceDir}/build-package",
      "cacheVariables": {
        "CHESS3D_PACKAGE": "ON",
        "CHESS3D_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    { "name": "windows-mingw",   "configurePreset": "windows-mingw"   },
    { "name": "linux-gcc",       "configurePreset": "linux-gcc"       },
    { "name": "ci-windows",      "configurePreset": "ci-windows"      },
    { "name": "ci-linux",        "configurePreset": "ci-linux"        },
    { "name": "package-windows", "configurePreset": "package-windows" },
    { "name": "package-linux",   "configurePreset": "package-linux"   }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "linux-gcc",
      "output": { "outputOnFailure": true },
      "filter": { "exclude": { "label": "slow" } }
    }
  ]
}
